#!/bin/bash
# lsearch: Search knowledge base

if [ -z "$1" ]; then
    echo "Usage: /lsearch <query>"
    echo "Example: /lsearch authentication flow"
    exit 1
fi

cd "${PWD}"
echo "Searching knowledge base for: $*"
python -m lsearch.cli search "$@" 2>/dev/null || echo "Error: lsearch not installed. Run: pip install lsearch"
